{
  "name": "temp-blueprint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --port 5173 --strictPort",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "stop": "node scripts/stop-dev.js"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.3.1",
    "@blueprintjs/icons": "^6.1.0",
    "@blueprintjs/select": "^6.1.4",
    "@blueprintjs/table": "^6.0.19",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.4"
  }
}
